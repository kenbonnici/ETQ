{
  "inputs_source": "specs/excel_prototype/analysis/step1_inputs_yellow_grouped.csv",
  "outputs": {
    "cash_chart": {
      "early_series": "RetEarly_Engine!ChartCash_Early",
      "norm_series": "ChartCash_Norm"
    },
    "net_worth_chart": {
      "early_series": "RetEarly_Engine!ChartNW_Early",
      "norm_series": "ChartNW_Norm"
    }
  },
  "timeline": {
    "age_range": "Ret* row 3",
    "year_range": "Ret* row 2",
    "module": "timeline.ts"
  },
  "module_mapping": [
    {
      "excel_block": "Ret* rows 5-17",
      "meaning": "income stack",
      "modules": [
        "employmentIncome.ts",
        "otherIncome.ts",
        "pension.ts",
        "eventAdjustments.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 20-46",
      "meaning": "expense/outflow stack",
      "modules": [
        "livingCosts.ts",
        "loanAmortization.ts",
        "creditAndOtherLoans.ts",
        "eventAdjustments.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 48-50",
      "meaning": "cash recursion",
      "modules": [
        "runScenarioNorm.ts",
        "runScenarioEarly.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 52-66",
      "meaning": "net worth without liquidation",
      "modules": [
        "assetGrowth.ts",
        "loanAmortization.ts",
        "creditAndOtherLoans.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 75-156",
      "meaning": "liquidation / disposal logic",
      "modules": [
        "liquidation.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 159-172",
      "meaning": "net worth with liquidation",
      "modules": [
        "liquidation.ts",
        "runScenarioNorm.ts",
        "runScenarioEarly.ts"
      ]
    },
    {
      "excel_block": "Ret* rows 183/184 and 201/202",
      "meaning": "chart output staging",
      "modules": [
        "index.ts"
      ]
    }
  ],
  "approved_intent_updates": [
    "pension reduction = max(0, (B19 - earlyRetAge)) * B157",
    "liquidation ordering ignores legacy B165 branch; defaults cheapest-first when unset; blanks in B166:B168 treated as 0"
  ]
}
