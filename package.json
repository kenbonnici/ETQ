{
  "name": "etq-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:runtime && npm run test:ui",
    "test:golden": "node --import tsx --test specs/runtime/golden.test.ts",
    "test:invariants": "node --import tsx --test specs/runtime/invariants.test.ts",
    "test:runtime": "node --import tsx --test specs/runtime/*.test.ts",
    "test:update-snapshots": "node --import tsx specs/runtime/golden/updateSnapshots.ts",
    "test:ui": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@fontsource-variable/cormorant-garamond": "^5.2.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
